# ==============================================================================
# Doctor Roster Application - Environment Configuration
# ==============================================================================
# Copy this file to './backend/.env' and fill in your actual values.
# The frontend automatically proxies requests from http://localhost:3000 to http://localhost:5000/api.

# Backend Port
PORT=5000

# Supabase Database Connection
# Set DATABASE_URL to your Supabase Transaction Pooler URL.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Supabase Client Credentials
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
